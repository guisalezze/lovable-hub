PORT=3000

# Supabase — obter em: Project Settings > API
SUPABASE_URL=https://SEU_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...    # service_role key (SECRETA — nunca no frontend)

# Opcional — e-mail de alerta quando sessão Baileys cair
ALERT_RECIPIENT_EMAIL=

# Tuning de save do auth Baileys (não precisa mudar normalmente)
AUTH_SAVE_DEBOUNCE_MS=3000
AUTH_SAVE_MAX_WAIT_MS=10000

# NOTAS:
# - Chaves do Resend ficam por remetente na tabela email_senders
# - Tokens da Meta ficam por conta na tabela whatsapp_api_accounts
# - Copie para .env e preencha os valores reais
